# --- Jai build artifacts ---
/.build/
/.build-package/
/jai-lsp
/jai-lsp.dSYM/

# --- VSCode extension ---
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/*.vsix
# Bundled binaries — drop them in per-platform when packaging, keep them out of git.
vscode-extension/bin/jai-lsp-*

# --- Zed extension (Rust/WASM) ---
zed-extension/target/
zed-extension/Cargo.lock
zed-extension/bin/jai-lsp-*
# Built by Zed at extension-install time; not source.
zed-extension/extension.wasm
zed-extension/grammars/

# --- macOS ---
.DS_Store

# --- Editor / IDE noise ---
# (Keep vscode-extension/.vscode/ — its launch.json / tasks.json are part of the dev setup.)
.idea/
*.swp
*.swo
